// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NextAuth.js required models
model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id               String    @id @default(cuid())
  name             String?
  email            String    @unique
  emailVerified    DateTime? @map("email_verified")
  image            String?
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  
  // Subscription and credits
  plan             Plan      @default(FREE)
  credits          Int       @default(5) // Free tier starts with 5 credits
  totalCreditsUsed Int       @default(0) @map("total_credits_used")
  subscriptionId   String?   @unique @map("subscription_id")
  customerId       String?   @unique @map("customer_id") // Stripe customer ID
  
  // Usage tracking
  dailyGenerations Int       @default(0) @map("daily_generations")
  lastResetDate    DateTime? @map("last_reset_date")
  
  // Relations
  accounts         Account[]
  sessions         Session[]
  generations      Generation[]
  payments         Payment[]

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verificationtokens")
}

// Custom models for our app
model Generation {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  prompt    String   @db.Text
  imageUrl  String   @map("image_url")
  width     Int
  height    Int
  model     String
  credits   Int      // Credits used for this generation
  createdAt DateTime @default(now()) @map("created_at")
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("generations")
}

model Payment {
  id               String        @id @default(cuid())
  userId           String        @map("user_id")
  stripePaymentId  String        @unique @map("stripe_payment_id")
  amount           Int           // Amount in cents
  currency         String        @default("usd")
  status           PaymentStatus
  type             PaymentType
  credits          Int?          // Credits purchased (for credit purchases)
  plan             Plan?         // Plan purchased (for subscriptions)
  createdAt        DateTime      @default(now()) @map("created_at")
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("payments")
}

// Enums
enum Plan {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum PaymentType {
  SUBSCRIPTION
  CREDITS
  ONE_TIME
}